<Window x:Class="FirewallManager.ConfigReconcileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="config.json differs from built-in defaults"
        Height="Auto" Width="720" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0a0e14" FontFamily="Segoe UI">
    <Border Padding="24,20">
        <StackPanel>
            <TextBlock Text="config.json differs from the built-in defaults"
                       FontSize="16" FontWeight="Bold" Foreground="#f9fafb"/>
            <TextBlock TextWrapping="Wrap" Foreground="#9ca3af" FontSize="12" Margin="0,6,0,0"
                       Text="For each section below, choose which to use. The built-in defaults are the trusted baseline; the config file is your editable override. You'll only be asked again if config.json changes."/>

            <StackPanel x:Name="SectionsPanel" Margin="0,16,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="BtnKeepAll" Content="Keep all built-in" Click="BtnKeepAll_Click"
                        Background="#374151" Foreground="#e5e7eb" BorderThickness="0"
                        Padding="14,7" Margin="0,0,8,0" Cursor="Hand"/>
                <Button x:Name="BtnOk" Content="Apply choices" Click="BtnOk_Click"
                        Background="#1d4ed8" Foreground="White" BorderThickness="0"
                        Padding="14,7" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
