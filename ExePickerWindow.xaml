<Window x:Class="FirewallManager.ExePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Executable" Height="360" Width="680"
        Background="#111827" FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Multiple matches found" FontSize="15" FontWeight="Bold"
                       Foreground="#f9fafb"/>
            <TextBlock Text="Sub-path matches are shown first (★). Select the correct executable:"
                       Foreground="#9ca3af" FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>

        <ListBox x:Name="PathList" Grid.Row="1"
                 Background="#1f2937" Foreground="#f9fafb"
                 BorderBrush="#374151" BorderThickness="1"
                 SelectionMode="Single"
                 MouseDoubleClick="PathList_DoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4,3">
                        <TextBlock Text="{Binding Display}" FontWeight="{Binding Weight}"
                                   Foreground="{Binding Color}"/>
                        <TextBlock Text="{Binding Path}" Foreground="#6b7280" FontSize="11"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="6,2"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1d4ed8"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#374151"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Select" Background="#15803d" Foreground="White"
                    BorderThickness="0" Padding="16,7" Cursor="Hand"
                    Click="BtnSelect_Click" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Background="#374151" Foreground="White"
                    BorderThickness="0" Padding="16,7" Cursor="Hand"
                    Click="BtnCancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
