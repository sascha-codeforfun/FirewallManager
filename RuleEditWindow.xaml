<Window x:Class="FirewallManager.RuleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Rule" Height="620" Width="560"
        Background="#1c1917" FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="110"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1f2937"/>
            <Setter Property="Foreground" Value="#f9fafb"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="#f9fafb"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#f9fafb"/>
            <Setter Property="Background" Value="#1f2937"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="#292524" BorderBrush="#374151" BorderThickness="1" CornerRadius="3"/>
                            <ContentPresenter Margin="10,0,28,0" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              TextBlock.Foreground="#f9fafb"/>
                            <ToggleButton BorderThickness="0" Background="Transparent"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path Data="M0,0 L5,5 L10,0" Stroke="#9ca3af" StrokeThickness="1.5"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#292524" BorderBrush="#374151" BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer Background="#292524"><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#f9fafb"/>
            <Setter Property="Background" Value="#1f2937"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextBlock.Foreground="#f9fafb"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#374151"/></Trigger>
                            <Trigger Property="IsSelected"  Value="True"><Setter TargetName="bg" Property="Background" Value="#1d4ed8"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnAction" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger>
                            <Trigger Property="IsEnabled"   Value="False"><Setter Property="Opacity" Value="0.35"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="track" CornerRadius="11" Background="#374151"/>
                            <Ellipse x:Name="thumb" Width="16" Height="16" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#15803d"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TagBtn" TargetType="Button">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="#e5e7eb"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4b5563"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock x:Name="TitleText" Text="Edit Rule" FontSize="17" FontWeight="Bold"
                       Foreground="#f9fafb" VerticalAlignment="Center"/>
            <Border x:Name="SourceBadge" CornerRadius="3" Padding="6,2" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="SourceLabel" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
            </Border>
            <TextBlock x:Name="ReadOnlyLabel" Text="  (read-only)" Foreground="#6b7280"
                       FontSize="12" VerticalAlignment="Center" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Name -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtName" Width="360"/>
                </StackPanel>

                <!-- Direction + Action -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Direction" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CboDirection" Width="120" Margin="0,0,12,0">
                        <ComboBoxItem Content="In"/>
                        <ComboBoxItem Content="Out"/>
                    </ComboBox>
                    <TextBlock Text="Action" Style="{StaticResource FieldLabel}" Width="60"/>
                    <ComboBox x:Name="CboAction" Width="120">
                        <ComboBoxItem Content="Allow"/>
                        <ComboBoxItem Content="Block"/>
                    </ComboBox>
                </StackPanel>

                <!-- Protocol + Ports -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Protocol" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CboProtocol" Width="120" Margin="0,0,12,0">
                        <ComboBoxItem Content="TCP"/>
                        <ComboBoxItem Content="UDP"/>
                        <ComboBoxItem Content="Any"/>
                    </ComboBox>
                    <TextBlock Text="Port(s)" Style="{StaticResource FieldLabel}" Width="60"/>
                    <TextBox x:Name="TxtPorts" Width="160" ToolTip="e.g. 443  or  80,443"/>
                </StackPanel>

                <!-- Remote Address -->
                <StackPanel Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Remote Address" Style="{StaticResource FieldLabel}"/>
                        <ToggleButton x:Name="TogAny" Style="{StaticResource ToggleStyle}"
                                      Checked="TogAny_Checked" Unchecked="TogAny_Unchecked"/>
                        <TextBlock Text="Any destination" Foreground="#6b7280" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- IP tag list -->
                    <Border x:Name="IPSection" Background="#292524" CornerRadius="5"
                            Padding="8" Margin="110,0,0,0" BorderBrush="#374151" BorderThickness="1">
                        <StackPanel>
                            <WrapPanel x:Name="IPTagPanel" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtNewIP" Width="220" Height="28"
                                         ToolTip="IP, CIDR range (e.g. 10.0.0.0/24) or hostname"/>
                                <Button Content="+ Add" Background="#1d4ed8" Foreground="White"
                                        BorderThickness="0" Padding="10,4" Margin="6,0,0,0"
                                        Cursor="Hand" Click="BtnAddIP_Click"
                                        Style="{StaticResource BtnAction}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Program -->
                <StackPanel Margin="0,10,0,6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Program" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtProgram" Width="270" ToolTip="Full path to .exe or leave empty for any process"/>
                        <Button Content="…" Background="#374151" Foreground="White"
                                BorderThickness="0" Padding="10,5" Margin="6,0,0,0"
                                Cursor="Hand" Click="BtnBrowseExe_Click"
                                Style="{StaticResource BtnAction}"/>
                        <Button Content="↺ Update" Background="#374151" Foreground="White"
                                BorderThickness="0" Padding="10,5" Margin="6,0,0,0"
                                Cursor="Hand" Click="BtnUpdateLocation_Click"
                                Style="{StaticResource BtnAction}"
                                ToolTip="Scan for updated exe path based on current path pattern"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="110,0,0,0">
                        <TextBox x:Name="TxtWindowsAppsSearch" Width="160" Height="26"
                                 ToolTip="Type exe name to scan WindowsApps (e.g. Claude.exe)"
                                 Padding="6,3"/>
                        <Button Content="🔍 Scan WindowsApps" Background="#374151" Foreground="White"
                                BorderThickness="0" Padding="10,4" Margin="6,0,0,0"
                                Cursor="Hand" Click="BtnScanWindowsApps_Click"
                                Style="{StaticResource BtnAction}"
                                ToolTip="Scan C:\Program Files\WindowsApps\ for this exe (requires admin)"/>
                    </StackPanel>
                </StackPanel>

                <!-- DNS companion toggles — shown when exe path is set -->
                <Border x:Name="DnsCompanionPanel" Background="#1a2535" CornerRadius="5"
                        Margin="110,0,0,8" Padding="10,8" BorderBrush="#2d4a6b" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <ToggleButton x:Name="TogCreateDNS" Style="{StaticResource ToggleStyle}"
                                          IsChecked="False" Checked="TogCreateDNS_Changed" Unchecked="TogCreateDNS_Changed"/>
                            <TextBlock Text="Also create UDP 53 (DNS) rule for this program"
                                       Foreground="#e5e7eb" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel x:Name="DnsRestrictPanel" Orientation="Horizontal" Visibility="Collapsed">
                            <ToggleButton x:Name="TogStandardDNS" Style="{StaticResource ToggleStyle}" IsChecked="False"/>
                            <TextBlock Foreground="#9ca3af" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="Standard DNS only  "/>
                                <Run x:Name="DnsIPsLabel" Foreground="#6b7280" FontSize="10"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- DNS restriction toggle — shown only when editing a UDP 53 rule -->
                <Border x:Name="DnsRulePanel" Background="#1a2535" CornerRadius="5"
                        Margin="110,0,0,8" Padding="10,8" BorderBrush="#2d4a6b" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="TogDNSRestrict" Style="{StaticResource ToggleStyle}" IsChecked="False"/>
                        <TextBlock Foreground="#e5e7eb" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0">
                            <Run Text="Restrict to standard DNS servers  "/>
                            <Run x:Name="DnsRestrictIPsLabel" Foreground="#6b7280" FontSize="10"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Active -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Active" Style="{StaticResource FieldLabel}"/>
                    <ToggleButton x:Name="TogActive" Style="{StaticResource ToggleStyle}" IsChecked="True"/>
                    <TextBlock x:Name="ActiveLabel" Text="Enabled" Foreground="#34d399"
                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Validation message -->
                <TextBlock x:Name="ValidationMsg" Foreground="#f87171" FontSize="11"
                           Margin="110,0,0,0" Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="EditStatus" Foreground="#6b7280" FontSize="11" VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="BtnSave" Content="💾  Save" Background="#15803d"
                    Style="{StaticResource BtnAction}" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Grid.Column="2" Content="Cancel" Background="#374151"
                    Style="{StaticResource BtnAction}" Click="BtnCancel_Click"/>
        </Grid>
    </Grid>
</Window>
