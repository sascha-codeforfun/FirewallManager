<Window x:Class="FirewallManager.ConsentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ἸΔΙΩΤΗΣ" Height="660" Width="600"
        SizeToContent="Height" MinHeight="620"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#0a0e14" FontFamily="Segoe UI">

    <Border Padding="34,28">
        <StackPanel>

            <!-- Impossible-value rejection banner (hidden in normal/first-run) -->
            <Border x:Name="RejectBanner" Visibility="Collapsed"
                    Background="#3b0a0a" BorderBrush="#7f1d1d" BorderThickness="1"
                    CornerRadius="6" Padding="14,10" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Impossible value rejected" Foreground="#f87171"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock x:Name="RejectText" Foreground="#fca5a5" FontSize="12"
                               TextWrapping="Wrap" FontFamily="Consolas, monospace"/>
                    <TextBlock Text="These could not represent any real address. The section was left at its built-in baseline. Fix config.json — μηδεὶς ἀδαὴς εἰσίτω."
                               Foreground="#fbbf24" FontSize="11" FontStyle="Italic"
                               TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Greek gate ── -->
            <TextBlock Text="ἸΔΙΩΤΗΣ" FontSize="40" FontWeight="Bold"
                       Foreground="#22d3ee" HorizontalAlignment="Center"
                       FontFamily="Palatino Linotype, Cambria, Georgia, serif"/>
            <TextBlock Text="μηδεὶς ἀδαὴς εἰσίτω" FontSize="20"
                       Foreground="#67e8f9" HorizontalAlignment="Center" Margin="0,6,0,2"
                       FontFamily="Palatino Linotype, Cambria, Georgia, serif"/>
            <TextBlock Text="let none unknowing enter" FontSize="12" FontStyle="Italic"
                       Foreground="#64748b" HorizontalAlignment="Center" Margin="0,0,0,18"/>

            <Border Height="1" Background="#1e293b" Margin="0,0,0,18"/>

            <!-- ── English contract ── -->
            <TextBlock TextWrapping="Wrap" Foreground="#cbd5e1" FontSize="13" LineHeight="20" Margin="0,0,0,12">
                <Run FontStyle="Italic" Foreground="#94a3b8">idiōtēs</Run>
                <Run Foreground="#64748b">(ἰδιώτης) — Greek: the layman; one who does not possess the knowledge of the craft.</Run>
            </TextBlock>

            <TextBlock TextWrapping="Wrap" Foreground="#f1f5f9" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8">
                This is a power tool for people who know what they are doing. Not a managed, guard-railed product.
            </TextBlock>

            <TextBlock TextWrapping="Wrap" Foreground="#cbd5e1" FontSize="13" LineHeight="20" Margin="0,0,0,12">
                It writes Windows Firewall policy directly to the registry, deletes and toggles rules, forces
                Group Policy refresh, and can disable name resolution. It can <Run FontWeight="Bold" Foreground="#f87171">sever
                this machine's network</Run>, <Run FontWeight="Bold" Foreground="#f87171">lock you out of the RDP session you
                are using right now</Run> with no remote way back, and break DNS, updates, or LAN access. Recovery may
                require physical or console access. It does exactly what you tell it — including the harmful thing.
                <Run FontWeight="Bold" Foreground="#fbbf24">Test in a VM first.</Run>
            </TextBlock>

            <TextBlock TextWrapping="Wrap" Foreground="#94a3b8" FontSize="13" FontStyle="Italic" Margin="0,0,0,18">
                I warn you, not that you will listen — it is your funeral, not mine.
            </TextBlock>

            <Border Height="1" Background="#1e293b" Margin="0,0,0,16"/>

            <!-- ── Oaths ── -->
            <CheckBox x:Name="ChkNotIdiotes" Foreground="#e2e8f0" FontSize="13" Margin="0,0,0,10"
                      Checked="Chk_Changed" Unchecked="Chk_Changed">
                <TextBlock TextWrapping="Wrap">I am no <Run FontStyle="Italic">idiōtēs</Run>.</TextBlock>
            </CheckBox>

            <CheckBox x:Name="ChkResponsibility" Foreground="#e2e8f0" FontSize="13" Margin="0,0,0,20"
                      Checked="Chk_Changed" Unchecked="Chk_Changed">
                <TextBlock TextWrapping="Wrap" Width="470">I know what I am doing, I have console / out-of-band
                    access or accept the risk of lockout, and I accept full responsibility.</TextBlock>
            </CheckBox>

            <!-- ── Buttons ── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnDecline" Content="Leave" Click="BtnDecline_Click"
                        Background="#334155" Foreground="#e2e8f0" BorderThickness="0"
                        Padding="20,8" Margin="0,0,10,0" Cursor="Hand" FontSize="13"/>
                <Button x:Name="BtnProceed" Content="Proceed" Click="BtnProceed_Click"
                        IsEnabled="False" Background="#0891b2" Foreground="White" BorderThickness="0"
                        Padding="24,8" Cursor="Hand" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
