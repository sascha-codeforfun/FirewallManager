<Window x:Class="FirewallManager.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Firewall Drop Log" Height="520" Width="1100"
        Background="#0a1a0e" FontFamily="Consolas" FontSize="12"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="FilterBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="Background" Value="#1a3320"/>
            <Setter Property="BorderBrush" Value="#2d4a35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2d4a35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterBtnActive" TargetType="Button" BasedOn="{StaticResource FilterBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1d4ed8"/>
            <Setter Property="BorderBrush" Value="#3b82f6"/>
        </Style>
        <Style x:Key="FilterBtnWarn" TargetType="Button" BasedOn="{StaticResource FilterBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#92400e"/>
            <Setter Property="BorderBrush" Value="#d97706"/>
        </Style>
        <Style x:Key="FilterBtnGood" TargetType="Button" BasedOn="{StaticResource FilterBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#15803d"/>
            <Setter Property="BorderBrush" Value="#22c55e"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <WrapPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="DROP Log Viewer" Foreground="#86efac"
                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center"
                       FontFamily="Segoe UI" Margin="0,0,12,0"/>
            <Button x:Name="BtnRefreshLog" Content="↺ Refresh"
                    Style="{StaticResource FilterBtn}" Margin="0,0,8,0"
                    Click="BtnRefreshLog_Click"/>
            <Border Width="1" Background="#2d4a35" Margin="0,2,8,2"/>
            <TextBlock Text="WF logging:" Foreground="#6b9970" FontSize="11"
                       VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,6,0"/>
            <Button x:Name="BtnLogDrops" Content="📥 Drops" Style="{StaticResource FilterBtn}"
                    Margin="0,0,3,0" Click="BtnLogDrops_Click"
                    ToolTip="Toggle Windows Firewall drop logging (what populates this view)"/>
            <Button x:Name="BtnLogAllow" Content="📤 Allow" Style="{StaticResource FilterBtn}"
                    Margin="0,0,8,0" Click="BtnLogAllow_Click"
                    ToolTip="Toggle Windows Firewall allowed-connection logging"/>
            <Border Width="1" Background="#2d4a35" Margin="0,2,8,2"/>
            <TextBlock Text="Scope:" Foreground="#6b9970" FontSize="11"
                       VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,6,0"/>
            <Button x:Name="BtnAll"    Content="All"       Style="{StaticResource FilterBtnActive}"
                    Margin="0,0,3,0" Click="BtnAll_Click"/>
            <Button x:Name="BtnLast5"  Content="⏱ 5 min"  Style="{StaticResource FilterBtn}"
                    Margin="0,0,3,0" Click="BtnLast5_Click"/>
            <Button x:Name="BtnLast30" Content="⏱ 30 min" Style="{StaticResource FilterBtn}"
                    Margin="0,0,8,0" Click="BtnLast30_Click"/>
            <Border Width="1" Background="#2d4a35" Margin="0,2,8,2"/>
            <TextBlock Text="Filter:" Foreground="#6b9970" FontSize="11"
                       VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,6,0"/>
            <Button x:Name="BtnDropsOnly"     Content="⚠ DROPs only"     Style="{StaticResource FilterBtn}"
                    Margin="0,0,3,0" Click="BtnDropsOnly_Click"/>
            <Button x:Name="BtnAllowsOnly"    Content="✔ Allows only"    Style="{StaticResource FilterBtn}"
                    Margin="0,0,3,0" Click="BtnAllowsOnly_Click"
                    ToolTip="Show only ALLOW records (Windows logs these only when allowed-connection logging is on)"/>
            <!-- Noise filter: master toggle (traffic light) + arrow opens surgical menu -->
            <Border CornerRadius="4" Background="#16331f" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnNoiseMaster" Style="{StaticResource FilterBtn}"
                            Click="BtnNoiseMaster_Click" Padding="8,4"
                            ToolTip="Noise filter: 🟢 all suppressed · 🟡 some · 🔴 none. Click to toggle all.">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="NoiseLight" Text="🟢" FontSize="11" Margin="0,0,5,0"/>
                            <TextBlock x:Name="NoiseLabel" Text="Noise" FontSize="11"
                                       Foreground="#34d399" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNoiseArrow" Content="▾" Style="{StaticResource FilterBtn}"
                            Click="BtnNoiseArrow_Click" Padding="6,4" FontSize="11"
                            ToolTip="Choose which noise categories to suppress"/>
                </StackPanel>
            </Border>
            <Popup x:Name="NoisePopup" PlacementTarget="{Binding ElementName=BtnNoiseArrow}"
                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                <Border Background="#0f2218" BorderBrush="#2d4a35" BorderThickness="1"
                        CornerRadius="6" Padding="10,8">
                    <StackPanel x:Name="NoiseMenuPanel" MinWidth="170">
                        <TextBlock Text="Suppress noise categories" Foreground="#6b9970"
                                   FontSize="10" Margin="0,0,0,6" FontFamily="Segoe UI"/>
                        <CheckBox Content="Multicast (224/239)"      Tag="Multicast"  IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"/>
                        <CheckBox Content="Broadcast (x.x.x.255)"    Tag="Broadcast"  IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"/>
                        <CheckBox Content="Link-local (169.254)"     Tag="Link-local" IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"/>
                        <CheckBox Content="NetBIOS (137/138/139)"    Tag="NetBIOS"    IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"/>
                        <CheckBox Content="mDNS (5353)"              Tag="mDNS"       IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"/>
                        <CheckBox Content="SSDP/WSD (1900/3702/5357)" Tag="SSDP/WSD"  IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"/>
                        <CheckBox Content="LLMNR (5355)"             Tag="LLMNR"      IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"/>
                        <CheckBox Content="Loopback (127.x)"         Tag="Loopback"   IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"/>
                        <CheckBox Content="DNS to configured resolver" Tag="DNS (configured)" IsChecked="True"
                                  Foreground="#e5e7eb" Margin="0,2" Checked="NoiseCategory_Toggled" Unchecked="NoiseCategory_Toggled"
                                  ToolTip="Hide DNS to your configured resolver only. DNS to any other server always shows as a warning."/>
                    </StackPanel>
                </Border>
            </Popup>
            <Border Width="1" Background="#2d4a35" Margin="0,2,8,2"/>
            <Button x:Name="BtnExport" Content="💾 Export" Style="{StaticResource FilterBtn}"
                    Margin="0,0,3,0" Click="BtnExport_Click"
                    ToolTip="Save current view to a text file"/>
            <TextBlock x:Name="LogCount" Foreground="#6b9970" FontSize="11"
                       VerticalAlignment="Center" Margin="12,0,0,0" FontFamily="Segoe UI"/>
        </WrapPanel>

        <!-- Log grid — IsReadOnly=False + ClipboardCopyMode enables Ctrl+C -->
        <DataGrid x:Name="LogGrid" Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="Cell"
                  ClipboardCopyMode="IncludeHeader"
                  Background="#0a1a0e" Foreground="#e5e7eb"
                  BorderThickness="0" RowBackground="#0a1a0e"
                  AlternatingRowBackground="#0f2218"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#1a3320"
                  ColumnHeaderHeight="34" RowHeight="28"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDnsAnomaly}" Value="True">
                            <Setter Property="Background" Value="{Binding RowTint}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu x:Name="LogContextMenu" Opened="LogContextMenu_Opened">
                    <MenuItem x:Name="MnuWhoOwns" Header="Who owns this connection?"
                              Click="MnuWhoOwns_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1e3a5f"/>
                    <Setter Property="Foreground" Value="#93c5fd"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="#1a3320"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"      Binding="{Binding Time}"      Width="145"/>
                <DataGridTextColumn Header="Action"    Binding="{Binding Action}"    Width="65">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="DROP">
                                    <Setter Property="Foreground" Value="#f87171"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                                <Trigger Property="Text" Value="ALLOW">
                                    <Setter Property="Foreground" Value="#34d399"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Proto"     Binding="{Binding Protocol}"  Width="60"/>
                <DataGridTextColumn Header="Src IP"    Binding="{Binding SrcIP}"     Width="140"/>
                <DataGridTextColumn Header="Dst IP"    Binding="{Binding DstIP}"     Width="150"/>
                <DataGridTextColumn Header="Resolved"  Binding="{Binding ResolvedDisplay}"  Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding ResolvedBrush}"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Src Port"  Binding="{Binding SrcPort}"   Width="80"/>
                <DataGridTextColumn Header="Dst Port"  Binding="{Binding DstPort}"   Width="80"/>
                <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="80"/>
                <DataGridTextColumn Header="Rule"      Binding="{Binding RuleName}"  Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding RuleBrush}"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontStyle"  Value="Italic"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Copy hint -->
        <TextBlock Grid.Row="2" Text="Tip: click a cell then Ctrl+C to copy  |  select multiple rows with Shift/Ctrl+Click"
                   Foreground="#2d4a35" FontSize="10" Margin="0,5,0,2" FontFamily="Segoe UI"/>

        <TextBlock Grid.Row="3" x:Name="LogPath" Foreground="#2d4a35"
                   FontSize="10" FontFamily="Segoe UI"/>
    </Grid>
</Window>
